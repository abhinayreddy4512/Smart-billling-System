generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  shopName  String?
  ownerName String?
  phone     String?
  gstNo     String?
  village   String?
  mandal    String?
  district  String?
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farmers   Farmer[]
  products  Product[]
}

model Farmer {
  id               String            @id @default(cuid())
  farmerNo         String            // e.g. "1001"
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  phone            String
  email            String?
  photoUrl         String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  @@unique([userId, farmerNo])
  bills            Bill[]
  cashTransactions CashTransaction[]
  cropLogs         CropLog[]
  cropSettlements  CropSettlement[]
}

model Product {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String   // 'FERTILIZER' or 'PESTICIDE'
  name      String
  size      String?  // '50kg', '1 Litre', etc.
  quantity  Int      @default(0) // Number of items
  price     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bill {
  id         String   @id @default(cuid())
  farmerId   String
  farmer     Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  category   String   // 'FERTILIZER' or 'PESTICIDE'
  product    String
  quantity   Int
  price      Float
  total      Float
  photoProof String?  @db.Text
  date       DateTime @default(now())
}

model CashTransaction {
  id         String   @id @default(cuid())
  farmerId   String
  farmer     Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  type       String   // 'TAKEN' or 'GIVEN'
  amount     Float
  photoProof String?  @db.Text
  date       DateTime @default(now())
}

model CropLog {
  id          String   @id @default(cuid())
  farmerId    String
  farmer      Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  cropType    String   // 'COTTON' or 'MIRCHI'
  bagWeights  Json     // array of numbers
  totalWeight Float
  price       Float?   @default(0) // price per kg
  isSettled   Boolean  @default(false)
  date        DateTime @default(now())
}

model CropSettlement {
  id          String   @id @default(cuid())
  farmerId    String
  farmer      Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  amount      Float
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}
